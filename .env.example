# ============================================
# Vibe Framework Demo - Environment Configuration
# ============================================
# Copy this file to .env and add your API keys
# You only need ONE provider to get started

# ============================================
# Recommended: FREE & FAST Providers
# ============================================

# Groq - Extremely fast, generous free tier
# Get your key: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Gemini - Google's AI, free tier available
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# Cloud AI Providers (Paid)
# ============================================

# OpenAI - GPT-4, GPT-4o-mini
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic - Claude models
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DeepSeek - Budget-friendly option
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Grok - xAI's models
GROK_API_KEY=your-grok-api-key-here

# ============================================
# LOCAL AI Model Configuration (FREE!)
# ============================================
# Use this for completely free, self-hosted AI
# Requires running a local model server (Ollama, etc.)

# AUTOHEAL_AI_PROVIDER=LOCAL
# LOCAL_MODEL_URL=https://your-tunnel.trycloudflare.com
# LOCAL_MODEL_API_PATH=/v1/chat/completions
# LOCAL_MODEL_NAME=deepseek-coder-v2:16b
# LOCAL_MODEL_FORMAT=openai
# LOCAL_MODEL_TIMEOUT=60000
# LOCAL_MODEL_TEMPERATURE=0.1
# LOCAL_MODEL_MAX_TOKENS=2048

# ============================================
# Video Recording Configuration
# ============================================
# Video recording mode: off | on | retain-on-failure | on-first-retry
VIBE_VIDEO_MODE=retain-on-failure

# Video resolution (width x height)
VIBE_VIDEO_WIDTH=1280
VIBE_VIDEO_HEIGHT=720

# Video output directory
VIBE_VIDEO_DIR=./vibe-reports/videos

# ============================================
# Reporting Configuration
# ============================================
# Enable/disable report formats (true/false)
VIBE_HTML_REPORT=true
VIBE_JSON_REPORT=true
VIBE_CSV_REPORT=true
VIBE_CONSOLE_REPORT=true

# Include screenshots in reports (true/false)
VIBE_SCREENSHOTS=true

# Include videos in reports (true/false)
VIBE_INCLUDE_VIDEOS=true

# Report output directory
VIBE_OUTPUT_DIR=./vibe-reports

# ============================================
# Vibe Framework Settings
# ============================================
# Vibe mode: pure-ai | smart-cache | training | trained
VIBE_MODE=smart-cache

# AI Provider for Vibe (GROQ | GEMINI | OPENAI | etc.)
VIBE_AI_PROVIDER=GROQ

# ============================================
# Notes
# ============================================
# - Groq is recommended for getting started (fast + free)
# - Gemini is great for development (free tier)
# - Training mode eliminates AI costs in CI/CD
# - Smart caching reduces AI calls by 95-99%
# - Video modes:
#   * off: No video recording
#   * on: Always record videos
#   * retain-on-failure: Record and keep only failed tests (recommended)
#   * on-first-retry: Record only on first retry attempt
