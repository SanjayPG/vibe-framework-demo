# ============================================
# Vibe Framework Demo - Environment Configuration
# ============================================
# Copy this file to .env and configure your settings
#
# 🟢 MANDATORY - Required for the framework to work
# 🔵 OPTIONAL - Has default values, only set if you want to override
#
# ============================================

# ============================================
# 🟢 MANDATORY: AI Provider Configuration
# ============================================
# You MUST provide at least ONE API key for an AI provider
# Get started with Groq (fast & free): https://console.groq.com/

# Groq - Extremely fast, generous free tier (RECOMMENDED)
GROQ_API_KEY=your-groq-api-key-here

# OR use Gemini - Google's AI, free tier available
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OR use other providers (see below)

# ============================================
# 🟢 MANDATORY: Select Your AI Provider
# ============================================
# Options: GROQ | GEMINI | OPENAI | ANTHROPIC | DEEPSEEK | LOCAL
# Default: GROQ
VIBE_AI_PROVIDER=GROQ

# ============================================
# 🔵 OPTIONAL: Additional Cloud AI Providers
# ============================================
# Only needed if you want to use these specific providers

# OpenAI - GPT-4, GPT-4o-mini (PAID)
# Get your key: https://platform.openai.com/api-keys
#OPENAI_API_KEY=your-openai-api-key-here

# Anthropic - Claude models (PAID)
# Get your key: https://console.anthropic.com/
#ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DeepSeek - Budget-friendly option (PAID)
# Get your key: https://platform.deepseek.com/
#DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Grok - xAI's models (PAID)
# Get your key: https://console.x.ai/
#GROK_API_KEY=your-grok-api-key-here

# ============================================
# 🔵 OPTIONAL: Custom AI Model
# ============================================
# Override the default model for your selected provider
# If not set, uses provider-specific defaults:
#   GROQ: llama-3.3-70b-versatile
#   GEMINI: gemini-2.5-flash
#   OPENAI: gpt-4o-mini
#   ANTHROPIC: claude-3-5-sonnet-20241022
#   DEEPSEEK: deepseek-chat

# Examples:
#   GROQ: llama-3.3-70b-versatile, llama-3.1-70b-versatile, mixtral-8x7b-32768
#   GEMINI: gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
#   OPENAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
#   DEEPSEEK: deepseek-chat, deepseek-coder
#VIBE_AI_MODEL=llama-3.3-70b-versatile

# ============================================
# 🔵 OPTIONAL: LOCAL AI Model (100% FREE!)
# ============================================
# Use this for completely free, self-hosted AI
# Requires running a local model server (Ollama, LM Studio, etc.)
# Only needed if VIBE_AI_PROVIDER=LOCAL

#VIBE_AI_PROVIDER=LOCAL
#LOCAL_MODEL_URL=http://localhost:11434
#LOCAL_MODEL_API_PATH=/v1/chat/completions
#LOCAL_MODEL_NAME=deepseek-coder-v2:16b
#LOCAL_MODEL_FORMAT=openai
#LOCAL_MODEL_TIMEOUT=60000
#LOCAL_MODEL_TEMPERATURE=0.1
#LOCAL_MODEL_MAX_TOKENS=2048

# ============================================
# 🔵 OPTIONAL: Vibe Framework Mode
# ============================================
# Default: smart-cache
# Options:
#   - smart-cache: Cache AI responses (95-99% cost reduction) - RECOMMENDED
#   - pure-ai: No caching, every action uses AI (expensive but always fresh)
#   - training: Generate cache for production use (no AI calls after training)
#   - trained: Use pre-trained cache, no AI calls (CI/CD optimized)
#VIBE_MODE=smart-cache

# ============================================
# 🔵 OPTIONAL: Video Recording Configuration
# ============================================
# All have sensible defaults, only override if needed

# Video recording mode
# Default: retain-on-failure
# Options:
#   - off: No video recording
#   - on: Always record and keep all videos
#   - retain-on-failure: Record all, keep only failures (RECOMMENDED)
#   - on-first-retry: Record only on first retry attempt
#VIBE_VIDEO_MODE=retain-on-failure

# Video resolution (width x height)
# Default: 1280x720
#VIBE_VIDEO_WIDTH=1280
#VIBE_VIDEO_HEIGHT=720

# Video output directory
# Default: ./vibe-reports/videos
#VIBE_VIDEO_DIR=./vibe-reports/videos

# ============================================
# 🔵 OPTIONAL: Reporting Configuration
# ============================================
# All report formats are enabled by default

# Enable/disable report formats (true/false)
# Default: true for all
#VIBE_HTML_REPORT=true
#VIBE_JSON_REPORT=true
#VIBE_CSV_REPORT=true
#VIBE_CONSOLE_REPORT=true

# Include screenshots in reports
# Default: true
#VIBE_SCREENSHOTS=true

# Include videos in reports
# Default: true
#VIBE_INCLUDE_VIDEOS=true

# Report output directory
# Default: ./vibe-reports
#VIBE_OUTPUT_DIR=./vibe-reports

# ============================================
# 📝 Quick Start Guide
# ============================================
#
# 1. Copy this file: cp .env.example .env
#
# 2. Get a FREE API key from Groq:
#    https://console.groq.com/
#
# 3. Add your key to .env:
#    GROQ_API_KEY=gsk_your_actual_key_here
#    VIBE_AI_PROVIDER=GROQ
#
# 4. Run your tests:
#    npm test
#
# That's it! Everything else uses smart defaults.
#
# ============================================
# 💡 Pro Tips
# ============================================
#
# - Groq is fastest and FREE (recommended for development)
# - Gemini has generous free tier (great for CI/CD)
# - smart-cache mode reduces costs by 95-99%
# - retain-on-failure keeps videos only for failed tests
# - You only need ONE provider to get started
# - All reporting features are enabled by default
#
